---
import { getSiteSettings } from '../lib/settings'

const settings = await getSiteSettings()

const waNumber = settings.whatsapp?.replace(/\D/g, '') ?? '593979286633'
const waHref   = `https://wa.me/${waNumber}`
---

<footer class="py-20 px-6 lg:px-12 bg-brand-teal text-white" data-color="dark">
  <div class="max-w-[1600px] mx-auto border-t border-white pt-16 grid grid-cols-1 lg:grid-cols-4 gap-12">

    <!-- Col 1: Brand -->
    <div class="lg:col-span-1">
      <a href="/" class="group inline-block mb-6">
        <img
          src="https://assets.zyrosite.com/cdn-cgi/image/format=auto,w=375,h=236,fit=crop/YrDQXj4Jr9UWZDOn/logo-horizontal---impresion-AVLBNkzOnBCxe5Dz.png"
          alt="Logo Odontomed"
          class="h-10 w-auto object-contain transition-transform duration-300 group-hover:scale-105 theme-logo"
          width="200" height="50"
          loading="lazy"
        />
      </a>
      <p class="font-sans text-sm opacity-70 leading-relaxed">
        Odontomed es tu clínica dental en el Valle de los Chillos, en Conocoto, Quito. Especialistas en
        salud y estética dental para adultos y niños, con todas las especialidades en un solo lugar.
      </p>
    </div>

    <!-- Col 2: Contacto -->
    <div class="lg:col-span-1 flex flex-col font-sans text-sm tracking-wide">
      <p class="text-[0.6rem] uppercase text-white/60 mb-4 tracking-widest font-bold">Contacto & Ubicación</p>
      <address class="not-italic space-y-4 opacity-80">
        <p><strong>Dirección:</strong><br />Av. Jaime Roldos Aguilera, Quito, Ecuador.</p>
        <p><strong>Teléfono:</strong><br /><a href="tel:0979286633" class="hover:scale-125 transition-transform duration-300">097 928 6633</a></p>
        <p><strong>Horarios:</strong><br />Lun–Vie: 08h30 – 19h00<br />Sábados: 08h30 – 15h00</p>
      </address>
      <a
        href={waHref}
        target="_blank" rel="noopener noreferrer"
        class="inline-block bg-white text-brand-teal px-4 py-3 text-[0.65rem] uppercase tracking-widest transition-transform duration-300 mt-6 text-center font-bold w-fit border border-brand-accent hover:scale-105"
      >
        Agenda por WhatsApp
      </a>
    </div>

    <!-- Col 3: Nav + Redes -->
    <div class="lg:col-span-1 flex flex-col font-sans text-sm tracking-widest uppercase">
      <p class="text-[0.6rem] text-white/60 mb-4 font-bold">Navegación</p>
      <nav class="flex flex-col gap-4 opacity-80">
        <a href="/"          class="hover:scale-105 transition-transform duration-300 inline-block">Inicio</a>
        <a href="/nosotros"  class="hover:scale-105 transition-transform duration-300 inline-block">Nosotros</a>
        <a href="/servicios" class="hover:scale-105 transition-transform duration-300 inline-block">Servicios</a>
        <a href="/blog"      class="hover:scale-105 transition-transform duration-300 inline-block">Blog</a>
      </nav>

      <p class="text-[0.6rem] text-white/60 mb-4 mt-8 font-bold">Redes Sociales</p>
      <div class="flex gap-5 opacity-80">

        {settings.whatsapp && (
          <a href={waHref} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp" class="hover:scale-125 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
            </svg>
          </a>
        )}

        {settings.instagram && (
          <a href={settings.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:scale-125 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
        )}

        {settings.facebook && (
          <a href={settings.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="hover:scale-125 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        )}

        {settings.tiktok && (
          <a href={settings.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok" class="hover:scale-125 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/>
            </svg>
          </a>
        )}

      </div>
    </div>

    <!-- Col 4: SEO tagline -->
    <div class="lg:col-span-1 flex flex-col justify-end">
      <div class="border-t border-white/30 pt-6 mt-8 lg:mt-0">
        <p class="font-serif italic text-lg opacity-60 leading-relaxed">
          "Odontólogo en el Valle de los Chillos, odontología en Conocoto y clínica dental en Quito para toda la familia."
        </p>
        <p class="mt-8 opacity-40 lowercase font-sans text-xs">© 2026 Clínica Odontomed.</p>
      </div>
    </div>

  </div>
</footer>
