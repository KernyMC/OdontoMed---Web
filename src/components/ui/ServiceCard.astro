---
/**
 * ServiceCard.astro
 * Tarjeta de servicio con hover-reveal. Enlaza a /servicios/[slug].
 */
interface Props {
  slug:    string;
  title:   string;
  imgSrc:  string;
  desc:    string;
  alt?:    string;
}

const { slug, title, imgSrc, desc, alt = title } = Astro.props;
---

<a
  href={`/servicios/${slug}`}
  class="group relative rounded-[2rem] overflow-hidden aspect-[4/5] sm:aspect-square md:aspect-[4/5] shadow-sm hover:shadow-2xl transition-shadow duration-500 gsap-service-item block"
  aria-label={`Ver detalles de ${title}`}
>
  <img
    src={imgSrc}
    alt={alt}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
    loading="eager"
    width="400" height="500"
  />

  <!-- Gradiente base -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

  <!-- Overlay teal en hover -->
  <div class="absolute inset-0 bg-brand-teal/90 opacity-0 transition-opacity duration-500 ease-out group-hover:opacity-100 backdrop-blur-sm"></div>

  <!-- Contenido -->
  <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end z-10">
    <h3 class="font-serif text-3xl md:text-4xl text-white leading-none transform transition-transform duration-500 ease-out group-hover:-translate-y-2">
      {title}
    </h3>
    <div class="grid grid-rows-[0fr] transition-all duration-500 ease-out group-hover:grid-rows-[1fr]">
      <div class="overflow-hidden opacity-0 transition-opacity duration-500 delay-100 group-hover:opacity-100">
        <p class="font-sans text-sm text-white/90 mb-6 mt-4 leading-relaxed">{desc}</p>
        <span class="font-sans text-xs uppercase tracking-widest text-brand-light font-bold flex items-center gap-2">
          Ver más <span class="text-lg leading-none transform group-hover:translate-x-1 transition-transform">→</span>
        </span>
      </div>
    </div>
  </div>
</a>
