---
import BaseLayout  from '../layouts/BaseLayout.astro';
import Navbar      from '../components/Navbar.astro';
import Footer      from '../components/Footer.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';
import { services } from '../data/services';

const featuredServices = services.slice(0, 4);
---

<BaseLayout
  title="Odontomed | Clínica Dental en Conocoto, Valle de los Chillos"
  description="Clínica dental en Conocoto, Quito. Ortodoncia, implantes, carillas, endodoncia y medicina general. Tecnología de punta y atención personalizada para toda la familia."
  bodyTheme="dark"
>
  <Navbar />

  <!-- ── Hero ──────────────────────────────────────────────────── -->
  <section
    class="relative min-h-screen flex flex-col justify-center items-center px-4 pt-32 pb-16"
    data-color="dark"
  >
    <div class="absolute inset-0 z-0 overflow-hidden bg-brand-teal">
      <div class="absolute inset-0 bg-brand-teal/85 mix-blend-multiply z-10"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-brand-teal/50 z-10"></div>
      <video autoplay loop muted playsinline class="w-full h-full object-cover gsap-hero-bg scale-110 opacity-70" aria-hidden="true">
        <source src="https://res.cloudinary.com/di40d5qvz/video/upload/v1772684076/cz4s1rwzz9rmr0cwqgs9pmj2br_result__ldytjq.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="max-w-[1200px] w-full relative z-10 text-white mt-12 text-center flex flex-col items-center gsap-hero-content">
      <h2 class="gsap-hero-el font-sans text-[10px] md:text-xs tracking-[0.35em] uppercase mb-4 text-white/30 font-semibold flex items-center gap-4">
        <span class="w-8 h-px bg-white/20"></span>
        Centro Odontológico Integral
        <span class="w-8 h-px bg-white/20"></span>
      </h2>
      <h1 class="font-serif text-[4rem] sm:text-[5.5rem] lg:text-[7rem] leading-[0.9] tracking-tighter mb-6 drop-shadow-lg max-w-5xl mx-auto">
        <div class="overflow-hidden"><span class="gsap-hero-title inline-block">Especialistas en</span></div>
        <div class="overflow-hidden"><span class="gsap-hero-title inline-block text-[3rem] sm:text-[4.5rem] lg:text-[6rem] mt-2 italic text-white/90">Odontología</span></div>
        <div class="overflow-hidden"><span class="gsap-hero-title inline-block text-[2rem] sm:text-[3rem] lg:text-[4rem] mt-1 hero-outline-text">en el Valle de los Chillos</span></div>
      </h1>
      <div class="overflow-hidden mb-10 max-w-2xl mx-auto">
        <p class="gsap-hero-el font-sans text-lg md:text-xl font-light leading-relaxed drop-shadow-md text-white/80">
          Atención dental sin dolor, estética avanzada y tecnología de punta. Recupera tu confianza con nuestro equipo de expertos en Conocoto.
        </p>
      </div>
      <div class="gsap-hero-el flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto">
        <a
          href="https://wa.me/593979286633"
          target="_blank" rel="noopener noreferrer"
          class="bg-brand-accent text-white px-10 py-4 text-sm uppercase tracking-widest hover:bg-white hover:text-brand-teal transition-all duration-300 shadow-xl font-bold w-full sm:w-auto text-center border border-brand-accent flex justify-center items-center gap-2 group"
        >
          <svg class="w-5 h-5 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          Agendar Cita
        </a>
        <a
          href="/servicios"
          class="bg-transparent text-white px-10 py-4 text-sm uppercase tracking-widest hover:text-brand-light transition-colors duration-300 w-full sm:w-auto text-center font-bold border-b border-white hover:border-brand-light"
        >
          Ver Tratamientos
        </a>
      </div>
    </div>
  </section>

  <!-- ── Marquee ─────────────────────────────────────────────────── -->
  <section class="py-10 border-y border-[var(--text-color)] overflow-hidden" data-color="dark">
    <div class="whitespace-nowrap flex items-center">
      <div class="gsap-marquee font-serif text-[2.5rem] md:text-[4rem] leading-none uppercase tracking-tight whitespace-nowrap">
        &nbsp;ESTÉTICA DENTAL • IMPLANTES • ORTODONCIA • ODONTOPEDIATRÍA • ENDODONCIA •&nbsp;
      </div>
      <div class="gsap-marquee font-serif text-[2.5rem] md:text-[4rem] leading-none uppercase tracking-tight whitespace-nowrap" aria-hidden="true">
        &nbsp;ESTÉTICA DENTAL • IMPLANTES • ORTODONCIA • ODONTOPEDIATRÍA • ENDODONCIA •&nbsp;
      </div>
    </div>
  </section>

  <!-- ── Team Preview ────────────────────────────────────────────── -->
  <section class="py-32 px-6 lg:px-12" data-color="light">
    <div class="max-w-[1600px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="h-[70vh] w-full overflow-hidden relative">
        <div class="absolute inset-0 bg-brand-teal w-full h-full transform translate-x-4 translate-y-4"></div>
        <img
          src="https://images.unsplash.com/photo-1629909613654-28e377c37b09?q=80&w=2068&auto=format&fit=crop"
          alt="Equipo de odontólogos Odontomed en Conocoto, Quito"
          class="w-full h-full object-cover relative z-10 grayscale contrast-125 gsap-home-team-img"
          loading="lazy" width="800" height="1000"
        />
      </div>
      <div class="px-0 md:px-12">
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-accent gsap-home-team-text">El Equipo</span>
        <h2 class="font-serif text-[3.5rem] md:text-[5rem] leading-[0.9] mb-8 gsap-home-team-text">
          Conoce a tu <br /><span class="italic text-outline">odontólogo</span><br />en el Valle de los Chillos.
        </h2>
        <p class="font-sans text-lg leading-relaxed mb-8 max-w-lg gsap-home-team-text">
          En Odontomed cuentas con un equipo de especialistas con años de experiencia en Quito y el Valle
          de los Chillos. Diagnósticos honestos, planes personalizados y acompañamiento cercano en cada etapa.
        </p>
        <ul class="font-sans text-sm uppercase tracking-widest space-y-4 mb-12 gsap-home-team-text">
          <li class="flex items-center gap-3"><span class="w-8 h-[1px] bg-brand-accent"></span> Tratamientos para adultos y niños.</li>
          <li class="flex items-center gap-3"><span class="w-8 h-[1px] bg-brand-accent"></span> Todas las especialidades en un solo lugar.</li>
          <li class="flex items-center gap-3"><span class="w-8 h-[1px] bg-brand-accent"></span> Clínica moderna en Conocoto.</li>
        </ul>
        <div class="gsap-home-team-text">
          <a href="/nosotros" class="border-b border-[var(--text-color)] pb-2 font-sans text-sm uppercase tracking-widest hover:text-brand-accent transition-colors">
            Sobre nosotros
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Services Carousel ──────────────────────────────────────── -->
  <section class="py-32 px-6 lg:px-12 bg-brand-teal text-white" data-color="dark">
    <div class="max-w-[1600px] mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
        <div>
          <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-light gsap-services-el">Nuestras Especialidades</span>
          <h2 class="font-serif text-[4rem] md:text-[6rem] leading-[0.9] tracking-tighter gsap-services-el">
            Lo que <br /><span class="italic text-white/80">hacemos.</span>
          </h2>
        </div>
        <a
          href="/servicios"
          class="font-sans text-sm uppercase tracking-widest border-b border-white/40 pb-2 hover:border-white hover:text-brand-light transition-all gsap-services-el shrink-0"
        >
          Ver todos los servicios →
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 gsap-services-grid">
        {featuredServices.map((s) => <ServiceCard {...s} />)}
      </div>
    </div>
  </section>

  <!-- ── Reviews / Testimonials ──────────────────────────────────── -->
  <section class="py-32 px-6 lg:px-12 bg-brand-soft" data-color="soft">
    <div class="max-w-[1600px] mx-auto">
      <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-8 text-brand-accent gsap-reviews-el">Testimonios</span>
      <h2 class="font-serif text-[4rem] md:text-[6rem] leading-[0.9] tracking-tighter mb-20 text-brand-teal gsap-reviews-el">
        Lo que dicen<br /><span class="italic">nuestros pacientes.</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <figure class="gsap-review-item flex flex-col">
          <blockquote class="font-serif text-2xl leading-snug italic text-brand-teal mb-8 flex-1">
            "Vine con miedo al dentista y salí con una sonrisa que no quiero esconder. El equipo de Odontomed es increíble."
          </blockquote>
          <figcaption class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-teal flex items-center justify-center text-white font-serif font-bold text-lg">M</div>
            <div>
              <p class="font-sans text-sm font-bold text-brand-teal uppercase tracking-widest">María F.</p>
              <p class="font-sans text-xs text-brand-teal/60 uppercase tracking-widest">Conocoto</p>
            </div>
          </figcaption>
        </figure>
        <figure class="gsap-review-item flex flex-col">
          <blockquote class="font-serif text-2xl leading-snug italic text-brand-teal mb-8 flex-1">
            "Me hicieron el diseño de sonrisa digital y quedé impresionado. Los implantes se ven completamente naturales."
          </blockquote>
          <figcaption class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-accent flex items-center justify-center text-white font-serif font-bold text-lg">A</div>
            <div>
              <p class="font-sans text-sm font-bold text-brand-teal uppercase tracking-widest">Andrés R.</p>
              <p class="font-sans text-xs text-brand-teal/60 uppercase tracking-widest">Valle de los Chillos</p>
            </div>
          </figcaption>
        </figure>
        <figure class="gsap-review-item flex flex-col">
          <blockquote class="font-serif text-2xl leading-snug italic text-brand-teal mb-8 flex-1">
            "Llevo a mis hijos desde pequeños. La atención en odontopediatría es excelente: pacientes, profesionales y muy amables."
          </blockquote>
          <figcaption class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-full bg-brand-light flex items-center justify-center text-brand-teal font-serif font-bold text-lg">C</div>
            <div>
              <p class="font-sans text-sm font-bold text-brand-teal uppercase tracking-widest">Carolina V.</p>
              <p class="font-sans text-xs text-brand-teal/60 uppercase tracking-widest">Quito</p>
            </div>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ── Map / Location ─────────────────────────────────────────── -->
  <section class="py-32 px-6 lg:px-12 border-t border-[var(--text-color)] bg-brand-teal text-white" data-color="dark">
    <div class="max-w-[1600px] mx-auto flex flex-col lg:flex-row gap-16 items-center">
      <div class="w-full lg:w-1/3">
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-white/60 gsap-map-el">Encuéntranos</span>
        <h2 class="font-serif text-[4rem] md:text-[5rem] leading-[0.9] mb-8 gsap-map-el">
          Nuestra <br /><span class="italic" style="-webkit-text-stroke: 1px white; color: transparent;">Ubicación.</span>
        </h2>
        <div class="bg-white border border-white/20 p-8 rounded-2xl gsap-map-el transition-colors duration-500">
          <h3 class="font-serif text-3xl text-brand-teal mb-2">ODONTOMED S.A.S</h3>
          <p class="font-sans text-sm text-brand-teal/60 mb-6">Clínica odontológica en Quito</p>
          <ul class="space-y-5 font-sans text-sm text-brand-teal/80 mb-8">
            <li class="flex items-start gap-4">
              <svg class="w-5 h-5 text-brand-accent mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span><strong>Dirección:</strong><br />Av. Jaime Roldos Aguilera, Quito</span>
            </li>
            <li class="flex items-start gap-4">
              <svg class="w-5 h-5 text-brand-accent mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <span><strong>Teléfono:</strong><br /><a href="tel:0979286633" class="hover:text-brand-accent transition-colors">097 928 6633</a></span>
            </li>
            <li class="flex items-start gap-4">
              <svg class="w-5 h-5 text-brand-accent mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span><strong>Horario:</strong><br />Abre a las 8:00 a.m.</span>
            </li>
          </ul>
          <div class="grid grid-cols-2 gap-4">
            <a href="https://www.google.com/maps/place/ODONTOMED+S.A.S/@-0.3063063,-78.4876081,15z" target="_blank" rel="noopener noreferrer" class="border border-brand-teal text-brand-teal py-3 px-2 text-center text-xs uppercase tracking-widest hover:bg-brand-teal hover:text-white transition-all duration-300 rounded font-bold flex items-center justify-center gap-2">
              Cómo llegar
            </a>
            <a href="tel:0979286633" class="bg-brand-accent text-white py-3 px-2 text-center text-xs uppercase tracking-widest hover:bg-brand-teal transition-all duration-300 rounded font-bold flex items-center justify-center gap-2 shadow-md">
              Llamar
            </a>
          </div>
        </div>
      </div>
      <div class="w-full lg:w-2/3 h-[400px] lg:h-[600px] rounded-2xl overflow-hidden border border-white/10 gsap-map-el relative group">
        <div class="absolute inset-0 bg-brand-teal/20 mix-blend-multiply z-10 pointer-events-none group-hover:opacity-0 transition-opacity duration-500"></div>
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d31918.090443212226!2d-78.48760809999999!3d-0.30630630000000003!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x91d5992c4fb612c9%3A0x4d5b72bfbbb97405!2sODONTOMED%20S.A.S!5e0!3m2!1ses!2sec!4v1772683065507!5m2!1ses!2sec"
          width="100%" height="100%" style="border:0;" allowfullscreen loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación de Odontomed en Conocoto, Quito"
          class="filter grayscale group-hover:grayscale-0 transition-all duration-700"
        ></iframe>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap || !window.ScrollTrigger) return;

    // Navbar entrance — slides down from above as the hero reveals
    gsap.fromTo('#navbar',
      { y: -80, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, delay: 0.4, ease: 'power3.out', clearProps: 'transform,opacity' }
    );

    gsap.fromTo('.gsap-hero-title', { yPercent: 120 }, { yPercent: 0, duration: 1.5, stagger: 0.15, ease: 'power4.out' });
    gsap.fromTo('.gsap-hero-el',    { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 1, stagger: 0.1, ease: 'power4.out' });
    gsap.fromTo('.gsap-hero-bg',    { scale: 1.15 }, { scale: 1, duration: 2.5, ease: 'power2.out' });

    gsap.to('.gsap-hero-content', {
      yPercent: 20, opacity: 0, ease: 'none',
      scrollTrigger: { trigger: 'body', start: 'top top', end: '30% top', scrub: true },
    });

    gsap.to('.gsap-marquee', {
      xPercent: -50, ease: 'none',
      scrollTrigger: { trigger: '.gsap-marquee', start: 'top bottom', end: 'bottom top', scrub: 1.5 },
    });

    gsap.set('.gsap-home-team-img', { clipPath: 'inset(100% 0% 0% 0%)', scale: 1.1 });
    gsap.to('.gsap-home-team-img', {
      clipPath: 'inset(0% 0% 0% 0%)', scale: 1, duration: 1.5, ease: 'power3.inOut',
      scrollTrigger: { trigger: '.gsap-home-team-img', start: 'top 60%' },
    });

    gsap.fromTo('.gsap-home-team-text', { x: 50, opacity: 0 }, {
      x: 0, opacity: 1, duration: 1, stagger: 0.1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-home-team-img', start: 'top 50%' },
    });

    gsap.fromTo('.gsap-services-el', { y: 40, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-services-grid', start: 'top 80%' },
    });
    gsap.fromTo('.gsap-services-grid .gsap-service-item', { y: 60, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-services-grid', start: 'top 80%' },
    });

    gsap.fromTo('.gsap-reviews-el', { y: 40, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-review-item', start: 'top 80%' },
    });
    gsap.fromTo('.gsap-review-item', { y: 50, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-review-item', start: 'top 80%' },
    });

    gsap.fromTo('.gsap-map-el', { y: 50, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-map-el', start: 'top 75%' },
    });
  });
</script>
