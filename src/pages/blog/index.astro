---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar     from '../../components/Navbar.astro';
import Footer     from '../../components/Footer.astro';
import { articles } from '../../data/articles';

const featured = articles.find((a) => a.featured)!;
const grid     = articles.filter((a) => !a.featured);
---

<BaseLayout
  title="Blog | Odontomed — Consejos de Salud Dental en Conocoto"
  description="Artículos sobre salud dental, estética, prevención y novedades de Odontomed. Tu clínica dental de referencia en el Valle de los Chillos, Conocoto, Quito."
  bodyTheme="soft"
>
  <Navbar />

  <section class="pt-40 pb-32 px-6 lg:px-12 bg-brand-soft" data-color="soft">
    <div class="max-w-[1600px] mx-auto text-brand-teal">

      <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-8 text-brand-accent">Lecturas y Consejos</span>
      <h1 class="font-serif text-[5rem] md:text-[7rem] leading-[0.9] mb-20">Nuestro <span class="italic">Blog.</span></h1>

      <!-- Artículo destacado -->
      <a
        href={`/blog/${featured.slug}`}
        class="group cursor-pointer gsap-blog-item flex flex-col lg:flex-row gap-12 lg:gap-20 mb-20 border-b border-brand-teal/20 pb-20 block"
        aria-label={`Leer: ${featured.title}`}
      >
        <div class="w-full lg:w-3/5 overflow-hidden relative h-[50vh] lg:h-[65vh]">
          <div class="absolute inset-0 bg-brand-teal/10 mix-blend-multiply z-10 group-hover:opacity-0 transition-opacity duration-500"></div>
          <img
            src={featured.imgSrc} alt={featured.title}
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 transform group-hover:scale-105"
            loading="lazy" width="900" height="650"
          />
        </div>
        <div class="w-full lg:w-2/5 flex flex-col justify-center">
          <p class="text-[0.65rem] uppercase tracking-[0.2em] font-sans mb-4 text-brand-accent font-bold">
            {featured.category} <span class="opacity-50 font-normal ml-2">• {featured.readTime} de lectura</span>
          </p>
          <h2 class="font-serif text-[3.5rem] md:text-[4.5rem] leading-none mb-6 group-hover:italic transition-all duration-500">{featured.title}</h2>
          <p class="font-sans text-lg opacity-80 mb-8 leading-relaxed">{featured.excerpt}</p>
          <span class="font-sans text-xs uppercase tracking-widest text-brand-accent font-bold flex items-center gap-2 group-hover:text-brand-teal transition-colors">
            Leer artículo <span class="text-lg">→</span>
          </span>
        </div>
      </a>

      <!-- Grid de artículos -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 gsap-blog-grid">
        {grid.map((article) => (
          <a
            href={`/blog/${article.slug}`}
            class="group cursor-pointer block"
            aria-label={`Leer: ${article.title}`}
          >
            <div class="overflow-hidden mb-6 h-[40vh] relative">
              <div class="absolute inset-0 bg-brand-teal/10 mix-blend-multiply z-10 group-hover:opacity-0 transition-opacity duration-500"></div>
              <img
                src={article.imgSrc} alt={article.title}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
                loading="lazy" width="700" height="400"
              />
            </div>
            <p class="text-[0.65rem] uppercase tracking-[0.2em] font-sans mb-3 text-brand-accent font-bold">
              {article.category} <span class="opacity-50 font-normal ml-2">• {article.readTime} de lectura</span>
            </p>
            <h3 class="font-serif text-[2.5rem] leading-none mb-4 group-hover:italic transition-all">{article.title}</h3>
            <p class="font-sans text-base opacity-70 mb-6 line-clamp-2">{article.excerpt}</p>
            <div class="h-[1px] w-full bg-brand-teal scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap || !window.ScrollTrigger) return;
    gsap.fromTo('.gsap-blog-item', { y: 50, opacity: 0 }, {
      y: 0, opacity: 1, duration: 1, stagger: 0.2, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-blog-grid', start: 'top 70%' },
    });
  });
</script>
