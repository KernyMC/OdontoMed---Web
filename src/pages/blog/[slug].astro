---
import BaseLayout    from '../../layouts/BaseLayout.astro';
import Navbar        from '../../components/Navbar.astro';
import Footer        from '../../components/Footer.astro';
import {
  getPost,
  urlFor,
  formatDate,
  portableTextToHtml,
  extractToc,
} from '../../utils/sanity';
import { Icon } from 'astro-icon/components';

const { slug } = Astro.params;
const post = await getPost(slug!);

if (!post) {
  return Astro.redirect('/blog');
}

const toc      = extractToc(post.body ?? []);
const bodyHtml = portableTextToHtml(post.body ?? []);
const dateStr  = formatDate(post.publishedAt);

const pageUrl      = encodeURIComponent(`https://odonto-med.com/blog/${post.slug}`)
const shareTitle   = encodeURIComponent(post.title)
const shareLinkedIn = `https://www.linkedin.com/sharing/share-offsite/?url=${pageUrl}`
const shareFacebook = `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`
const shareX        = `https://twitter.com/intent/tweet?url=${pageUrl}&text=${shareTitle}`
const heroUrl  = post.image
  ? urlFor(post.image).width(1600).height(750).fit('crop').auto('format').url()
  : null;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": heroUrl,
  "datePublished": post.publishedAt,
  "inLanguage": "es-EC",
  "url": `https://odonto-med.com/blog/${post.slug}`,
  "author": {
    "@type": "Person",
    "name": post.author?.name ?? "Odontomed",
    "worksFor": {
      "@type": "MedicalOrganization",
      "name": "Odontomed",
      "url": "https://odonto-med.com"
    }
  },
  "publisher": {
    "@type": "MedicalOrganization",
    "@id": "https://odonto-med.com/#organization",
    "name": "Odontomed",
    "url": "https://odonto-med.com"
  },
  "articleSection": post.category,
  "keywords": `odontología, ${post.category?.toLowerCase()}, salud dental, Conocoto, Quito, Valle de los Chillos`
});
---

<BaseLayout
  title={`${post.title} | Blog Odontomed`}
  description={post.excerpt}
  ogImage={heroUrl ?? undefined}
  bodyTheme="light"
  schema={articleSchema}
>
  <Navbar />

  <article itemscope itemtype="https://schema.org/BlogPosting">

    <!-- Header -->
    <header class="pt-40 pb-16 px-6 lg:px-12 bg-white text-brand-teal" data-color="light">
      <div class="max-w-[1200px] mx-auto text-center">
        <nav class="mb-12 font-sans text-xs uppercase tracking-widest text-brand-teal/50 gsap-post-hero" aria-label="Ruta de navegación">
          <a href="/" class="hover:text-brand-accent transition-colors">Inicio</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href="/blog" class="hover:text-brand-accent transition-colors">Blog</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <span class="text-brand-accent font-bold">{post.category}</span>
        </nav>
        <h1 itemprop="headline" class="font-serif text-[4rem] md:text-[5.5rem] leading-[0.9] tracking-tighter mb-8 gsap-post-hero mx-auto max-w-5xl">
          {post.title}
        </h1>
        <div class="flex items-center justify-center gap-6 font-sans text-sm tracking-widest uppercase text-brand-teal/60 gsap-post-hero">
          <span itemprop="author" itemscope itemtype="https://schema.org/Person" class="flex items-center gap-2">
            {post.author?.photoUrl ? (
              <img src={post.author.photoUrl} alt={post.author.name} class="w-7 h-7 rounded-full object-cover" loading="lazy" decoding="async" />
            ) : (
              <span class="w-8 h-[1px] bg-brand-accent" aria-hidden="true"></span>
            )}
            Por <span itemprop="name">{post.author?.name ?? 'Odontomed'}</span>
          </span>
          <time itemprop="datePublished" datetime={post.publishedAt} class="italic normal-case font-serif text-lg">{dateStr}</time>
          {post.readTime && (
            <span class="bg-brand-teal/5 px-3 py-1 rounded-full text-[0.65rem] font-bold">{post.readTime} de lectura</span>
          )}
        </div>
      </div>
    </header>

    <!-- Hero image -->
    {heroUrl && (
      <section class="px-6 lg:px-12 pb-20 bg-white">
        <div class="max-w-[1600px] mx-auto h-[60vh] md:h-[75vh] overflow-hidden gsap-post-img-container">
          <img
            itemprop="image"
            src={heroUrl}
            alt={post.image?.alt ?? post.title}
            class="w-full h-full object-cover filter grayscale-[30%] hover:grayscale-0 transition-all duration-1000 transform hover:scale-105"
            loading="eager" width="1600" height="750"
          />
        </div>
      </section>
    )}

    <!-- Body + TOC -->
    <section class="pb-32 px-6 lg:px-12 bg-white">
      <div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row lg:items-start gap-16 xl:gap-24">

        <!-- TOC Sidebar -->
        {toc.length > 0 && (
          <aside class="w-full lg:w-[22%] hidden lg:block shrink-0">
            <div class="sticky top-32 border-l border-brand-teal/20 pl-8 py-2 gsap-post-toc">
              <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold mb-8 text-brand-teal">En este artículo</p>
              <nav class="flex flex-col gap-3 font-sans text-sm text-brand-teal/70" aria-label="Tabla de contenidos">
                {toc.map((item) => (
                  <a
                    href={item.href}
                    class="toc-link leading-snug hover:text-brand-accent hover:translate-x-1 transition-all duration-200"
                    data-toc-link
                  >
                    {item.label}
                  </a>
                ))}
              </nav>
              <div class="mt-12 pt-8 border-t border-brand-teal/20">
                <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold mb-5 text-brand-teal">Compartir</p>
                <div class="flex gap-3">
                  <a
                    href={shareLinkedIn}
                    target="_blank" rel="noopener noreferrer"
                    aria-label="Compartir en LinkedIn"
                    class="w-9 h-9 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-brand-teal"
                  >
                    <Icon name="ph:linkedin-logo" class="w-4 h-4" />
                  </a>
                  <a
                    href={shareFacebook}
                    target="_blank" rel="noopener noreferrer"
                    aria-label="Compartir en Facebook"
                    class="w-9 h-9 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-brand-teal"
                  >
                    <Icon name="ph:facebook-logo" class="w-4 h-4" />
                  </a>
                  <a
                    href={shareX}
                    target="_blank" rel="noopener noreferrer"
                    aria-label="Compartir en X (Twitter)"
                    class="w-9 h-9 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-brand-teal"
                  >
                    <Icon name="ph:x-logo" class="w-4 h-4" />
                  </a>
                </div>
              </div>
            </div>
          </aside>
        )}

        <!-- Contenido del artículo -->
        <div itemprop="articleBody" class="w-full lg:w-2/3 xl:w-7/12 article-content text-brand-teal gsap-post-content">

          {post.intro && (
            <p class="drop-cap">{post.intro}</p>
          )}

          {post.quote && (
            <blockquote>"{post.quote}"</blockquote>
          )}

          <div set:html={bodyHtml} />

          <!-- CTA final -->
          <div class="mt-20 p-10 bg-brand-teal/5 border border-brand-teal/20 text-center">
            <h3 class="font-serif text-3xl mb-4 italic text-brand-teal">¿Listo para transformar tu sonrisa?</h3>
            <p class="font-sans mb-8 opacity-80">Agenda una valoración sin compromiso con nuestros especialistas en Conocoto.</p>
            <a href="https://wa.me/593979286633" target="_blank" rel="noopener noreferrer" class="bg-brand-accent text-white px-8 py-4 text-xs uppercase tracking-widest hover:bg-brand-teal transition-colors font-bold inline-block">
              Agendar Evaluación Gratuita
            </a>
          </div>

        </div>
      </div>
    </section>

  </article>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap || !window.ScrollTrigger) return;

    gsap.fromTo('.gsap-post-hero', { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power2.out' });
    gsap.fromTo('.gsap-post-img-container',
      { clipPath: 'inset(10% 10% 10% 10%)', opacity: 0 },
      { clipPath: 'inset(0% 0% 0% 0%)', opacity: 1, duration: 1.5, delay: 0.3, ease: 'power3.inOut' }
    );
    gsap.fromTo('.gsap-post-toc', { x: -30, opacity: 0 }, {
      x: 0, opacity: 1, duration: 1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-post-content', start: 'top 70%' },
    });
    gsap.fromTo('.gsap-post-content > *', { y: 30, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.05, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-post-content', start: 'top 70%' },
    });
  });
</script>
