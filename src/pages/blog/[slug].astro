---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar     from '../../components/Navbar.astro';
import Footer     from '../../components/Footer.astro';
import { articles } from '../../data/articles';

export const prerender = true;

export function getStaticPaths() {
  return articles.map((article) => ({
    params: { slug: article.slug },
    props:  { article },
  }));
}

const { article } = Astro.props;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": article.title,
  "description": article.excerpt,
  "image": article.imgSrc,
  "datePublished": article.date,
  "inLanguage": "es-EC",
  "url": `https://odonto-med.com/blog/${article.slug}`,
  "author": {
    "@type": "Person",
    "name": "Dra. Julienne Hong",
    "worksFor": {
      "@type": "MedicalOrganization",
      "name": "Odontomed",
      "url": "https://odonto-med.com"
    }
  },
  "publisher": {
    "@type": "MedicalOrganization",
    "@id": "https://odonto-med.com/#organization",
    "name": "Odontomed",
    "url": "https://odonto-med.com"
  },
  "articleSection": article.category,
  "keywords": `odontología, ${article.category.toLowerCase()}, salud dental, Conocoto, Quito, Valle de los Chillos`
});
---

<BaseLayout
  title={`${article.title} | Blog Odontomed`}
  description={article.excerpt}
  ogImage={article.imgSrc}
  bodyTheme="light"
  schema={articleSchema}
>
  <Navbar />

  <article itemscope itemtype="https://schema.org/BlogPosting">

    <!-- Header -->
    <header class="pt-40 pb-16 px-6 lg:px-12 bg-white text-brand-teal" data-color="light">
      <div class="max-w-[1200px] mx-auto text-center">
        <nav class="mb-12 font-sans text-xs uppercase tracking-widest text-brand-teal/50 gsap-post-hero" aria-label="Ruta de navegación">
          <a href="/" class="hover:text-brand-accent transition-colors">Inicio</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <a href="/blog" class="hover:text-brand-accent transition-colors">Blog</a>
          <span class="mx-2" aria-hidden="true">/</span>
          <span class="text-brand-accent font-bold">{article.category}</span>
        </nav>
        <h1 itemprop="headline" class="font-serif text-[4rem] md:text-[5.5rem] leading-[0.9] tracking-tighter mb-8 gsap-post-hero mx-auto max-w-5xl">
          {article.title}
        </h1>
        <div class="flex items-center justify-center gap-6 font-sans text-sm tracking-widest uppercase text-brand-teal/60 gsap-post-hero">
          <span itemprop="author" itemscope itemtype="https://schema.org/Person" class="flex items-center gap-2">
            <span class="w-8 h-[1px] bg-brand-accent" aria-hidden="true"></span>
            Por <span itemprop="name">Dra. Julienne Hong</span>
          </span>
          <time itemprop="datePublished" datetime={article.date} class="italic normal-case font-serif text-lg">{article.date}</time>
          <span class="bg-brand-teal/5 px-3 py-1 rounded-full text-[0.65rem] font-bold">{article.readTime} de lectura</span>
        </div>
      </div>
    </header>

    <!-- Hero image -->
    <section class="px-6 lg:px-12 pb-20 bg-white">
      <div class="max-w-[1600px] mx-auto h-[60vh] md:h-[75vh] overflow-hidden gsap-post-img-container">
        <img
          itemprop="image"
          src={article.imgSrc} alt={article.title}
          class="w-full h-full object-cover filter grayscale-[30%] hover:grayscale-0 transition-all duration-1000 transform hover:scale-105"
          loading="eager" width="1600" height="750"
        />
      </div>
    </section>

    <!-- Body + TOC -->
    <section class="pb-32 px-6 lg:px-12 bg-white">
      <div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row gap-16 xl:gap-24">

        <!-- TOC Sidebar -->
        <aside class="w-full lg:w-1/4 hidden lg:block">
          <div class="sticky top-32 border-l border-brand-teal/20 pl-8 py-2 gsap-post-toc">
            <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold mb-8 text-brand-teal">En este artículo</p>
            <nav class="flex flex-col gap-4 font-sans text-sm opacity-80 text-brand-teal" aria-label="Tabla de contenidos">
              {article.toc.map((item) => (
                <a href={item.href} class="toc-link">{item.label}</a>
              ))}
            </nav>
            <div class="mt-16 pt-8 border-t border-brand-teal/20">
              <p class="font-sans text-xs uppercase tracking-[0.2em] font-bold mb-6 text-brand-teal">Compartir</p>
              <div class="flex gap-4">
                <button aria-label="Compartir en LinkedIn"  class="w-10 h-10 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-xs font-bold text-brand-teal">IN</button>
                <button aria-label="Compartir en Facebook"  class="w-10 h-10 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-xs font-bold text-brand-teal">FB</button>
                <button aria-label="Compartir en Twitter/X" class="w-10 h-10 border border-brand-teal/20 flex items-center justify-center hover:bg-brand-accent hover:text-white hover:border-brand-accent transition-colors rounded-full text-xs font-bold text-brand-teal">TW</button>
              </div>
            </div>
          </div>
        </aside>

        <!-- Contenido del artículo -->
        <div itemprop="articleBody" class="w-full lg:w-2/3 xl:w-7/12 article-content text-brand-teal gsap-post-content">

          <p class="drop-cap">{article.intro}</p>

          {article.sections.map((section, i) => (
            <>
              <h2 id={section.id}>{section.heading}</h2>
              <div set:html={section.body} />

              {section.list && (
                <ul class="list-none space-y-4 mb-8 font-sans opacity-85 text-lg">
                  {section.list.map((item) => (
                    <li class="flex items-start gap-3">
                      <span class="text-brand-accent">◆</span>
                      {item}
                    </li>
                  ))}
                </ul>
              )}

              {/* Quote after section 1 */}
              {i === 0 && (
                <blockquote>"{article.quote}"</blockquote>
              )}

              {/* Hero image reprise after section 2 */}
              {i === 1 && (
                <figure class="my-12">
                  <img
                    src={article.imgSrc} alt={`${article.title} — imagen ilustrativa`}
                    class="w-full h-auto object-cover grayscale-[20%]"
                    loading="lazy" width="1200" height="675"
                  />
                  <figcaption class="text-sm font-sans mt-4 opacity-60 text-center uppercase tracking-widest">
                    Clínica Odontomed · Conocoto, Valle de los Chillos.
                  </figcaption>
                </figure>
              )}
            </>
          ))}

          <!-- CTA final -->
          <div class="mt-20 p-10 bg-brand-teal/5 border border-brand-teal/20 text-center">
            <h3 class="font-serif text-3xl mb-4 italic text-brand-teal">¿Listo para transformar tu sonrisa?</h3>
            <p class="font-sans mb-8 opacity-80">Agenda una valoración sin compromiso con nuestros especialistas en Conocoto.</p>
            <a href="/contacto" class="bg-brand-accent text-white px-8 py-4 text-xs uppercase tracking-widest hover:bg-brand-teal transition-colors font-bold inline-block">
              Agendar Evaluación Gratuita
            </a>
          </div>

        </div>
      </div>
    </section>

  </article>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap || !window.ScrollTrigger) return;

    gsap.fromTo('.gsap-post-hero', { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power2.out' });
    gsap.fromTo('.gsap-post-img-container',
      { clipPath: 'inset(10% 10% 10% 10%)', opacity: 0 },
      { clipPath: 'inset(0% 0% 0% 0%)', opacity: 1, duration: 1.5, delay: 0.3, ease: 'power3.inOut' }
    );
    gsap.fromTo('.gsap-post-toc', { x: -30, opacity: 0 }, {
      x: 0, opacity: 1, duration: 1, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-post-content', start: 'top 70%' },
    });
    gsap.fromTo('.gsap-post-content > *', { y: 30, opacity: 0 }, {
      y: 0, opacity: 1, duration: 0.8, stagger: 0.05, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-post-content', start: 'top 70%' },
    });
  });
</script>
