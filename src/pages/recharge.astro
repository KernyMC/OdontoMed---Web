---
import { invalidateCache } from '../lib/cache'

export const prerender = false

const secret = import.meta.env.CACHE_RECHARGE_SECRET

let message = ''
let success: boolean | null = null

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData()
  const key  = (data.get('key') ?? '').toString().trim()

  if (!secret) {
    message = 'CACHE_RECHARGE_SECRET no está configurado en el servidor.'
    success = false
  } else if (key === secret) {
    invalidateCache()
    message = 'Cache vaciado. El próximo request a Sanity traerá datos frescos.'
    success = true
  } else {
    message = 'Clave incorrecta.'
    success = false
  }
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recargar Cache — Odontomed</title>
  <meta name="robots" content="noindex, nofollow" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: "Hanken Grotesk", system-ui, sans-serif;
      background: #f4f7f8;
      color: #448087;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .card {
      background: #fff;
      border: 1px solid #caddde;
      padding: 2.5rem;
      max-width: 420px;
      width: 100%;
    }

    .logo {
      font-size: 0.6rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: #189aa0;
      font-weight: 700;
      margin-bottom: 2rem;
    }

    h1 {
      font-family: Georgia, serif;
      font-size: 1.8rem;
      line-height: 1;
      margin-bottom: 0.5rem;
      color: #448087;
    }

    p.sub {
      font-size: 0.8rem;
      opacity: 0.6;
      margin-bottom: 2rem;
      line-height: 1.5;
    }

    label {
      display: block;
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    input[type="password"] {
      width: 100%;
      border: 1px solid #caddde;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      color: #448087;
      background: #f4f7f8;
      outline: none;
      margin-bottom: 1rem;
      font-family: inherit;
    }
    input[type="password"]:focus { border-color: #448087; background: #fff; }

    button {
      width: 100%;
      background: #189aa0;
      color: #fff;
      border: none;
      padding: 0.85rem 1rem;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      font-weight: 700;
      cursor: pointer;
      font-family: inherit;
      transition: background 0.2s;
    }
    button:hover { background: #448087; }

    .msg {
      margin-top: 1.25rem;
      padding: 0.85rem 1rem;
      font-size: 0.8rem;
      font-weight: 600;
      border-left: 3px solid;
    }
    .msg.ok    { background: #e8f7f7; border-color: #189aa0; color: #189aa0; }
    .msg.error { background: #fef2f2; border-color: #e05252; color: #b91c1c; }
  </style>
</head>
<body>
  <div class="card">
    <p class="logo">Odontomed — Admin</p>
    <h1>Recargar Cache</h1>
    <p class="sub">Vacía el cache del servidor para que los próximos requests traigan contenido actualizado de Sanity.</p>

    <form method="POST">
      <label for="key">Clave de acceso</label>
      <input type="password" id="key" name="key" autocomplete="off" required />
      <button type="submit">Vaciar cache</button>
    </form>

    {message && (
      <div class={`msg ${success ? 'ok' : 'error'}`}>
        {message}
      </div>
    )}
  </div>
</body>
</html>
