---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar     from '../components/Navbar.astro';
import Footer     from '../components/Footer.astro';
import { sanityClient, urlFor } from '../utils/sanity';

const allPhotos = await sanityClient.fetch<any[]>(`
  *[_type == "clinicPhoto"] | order(order asc, _createdAt asc) {
    _id, label, category, year,
    "photoUrl": photo.asset->url,
    photo
  }
`)

const oldPhotos    = allPhotos.filter(p => p.category === 'historia')
const clinicPhotos = allPhotos.filter(p => p.category === 'actual')
---

<BaseLayout
  title="Nosotros | Odontomed — Clínica Dental y Médica desde 1976"
  description="Conoce la historia, misión, visión y valores de Odontomed S.A. Dos generaciones transformando sonrisas y salud en el Valle de los Chillos desde 1976."
  bodyTheme="soft"
>
  <Navbar />

  <!-- ── Hero ──────────────────────────────────────────────────────────── -->
  <section class="pt-40 pb-32 px-6 lg:px-12 min-h-screen flex items-center bg-brand-soft" data-color="soft">
    <div class="max-w-[1400px] mx-auto text-center">
      <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-accent gsap-about-hero">
        Nuestra Historia
      </span>
      <h1 class="font-serif text-[4rem] md:text-[6rem] leading-[0.9] text-brand-teal mb-8 gsap-about-hero">
        Sobre <span class="italic" style="-webkit-text-stroke: 1px #448087; color: transparent;">Nosotros.</span>
      </h1>
      <p class="font-sans text-xl opacity-70 max-w-2xl mx-auto text-brand-teal mb-4 gsap-about-hero">
        Dos generaciones transformando sonrisas y salud en el Valle de los Chillos desde 1976.
      </p>
      <p class="font-sans text-sm uppercase tracking-[0.3em] text-brand-accent font-semibold gsap-about-hero">
        Odontomed S.A. — Conocoto, Quito
      </p>
      <div class="mt-16 flex flex-col sm:flex-row items-center justify-center gap-4 gsap-about-hero">
        <a
          href="/servicios"
          class="bg-brand-accent text-white px-8 py-4 text-xs uppercase tracking-widest font-bold inline-block hover:bg-brand-teal transition-colors"
        >
          Ver nuestros servicios
        </a>
        <a
          href="https://wa.me/593979286633"
          target="_blank" rel="noopener noreferrer"
          class="border-b border-brand-teal/40 pb-2 font-sans text-sm uppercase tracking-widest hover:text-brand-accent transition-colors text-brand-teal"
        >
          Agendar cita
        </a>
      </div>
    </div>
  </section>

  <!-- ── Misión & Visión ────────────────────────────────────────────────── -->
  <section id="mision" class="py-24 md:py-40 px-6 lg:px-12 bg-white" data-color="light">
    <div class="max-w-[1600px] mx-auto">

      <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-16 text-brand-accent gsap-mv-el">
        Identidad Corporativa
      </span>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-px bg-brand-teal/10 border border-brand-teal/10">

        <!-- Misión -->
        <div class="bg-white p-12 lg:p-16 gsap-mv-card">
          <p class="font-sans text-[0.6rem] uppercase tracking-[0.35em] text-brand-accent mb-6 font-semibold">01 — Misión</p>
          <h2 class="font-serif text-[3rem] md:text-[4.5rem] leading-[0.85] tracking-tighter text-brand-teal mb-10">
            ¿Por qué<br /><span class="italic">existimos?</span>
          </h2>
          <p class="font-sans text-lg leading-relaxed text-brand-teal/70 max-w-lg">
            Brindar servicios integrales y especializados en salud odontológica, médica y quirúrgica, combinando experiencia, innovación tecnológica y un trato humano, para mejorar la calidad de vida de nuestros pacientes.
          </p>
        </div>

        <!-- Visión -->
        <div class="bg-brand-teal p-12 lg:p-16 text-white gsap-mv-card">
          <p class="font-sans text-[0.6rem] uppercase tracking-[0.35em] text-brand-light mb-6 font-semibold">02 — Visión</p>
          <h2 class="font-serif text-[3rem] md:text-[4.5rem] leading-[0.85] tracking-tighter mb-10">
            ¿A dónde<br /><span class="italic text-white/80">vamos?</span>
          </h2>
          <p class="font-sans text-lg leading-relaxed text-white/70 max-w-lg">
            Ser el centro de referencia líder en el Valle de los Chillos, reconocido por nuestra excelencia clínica, trayectoria de más de 40 años y compromiso con la salud integral.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Trayectoria ────────────────────────────────────────────────────── -->
  <section class="py-24 md:py-40 px-6 lg:px-12 bg-brand-teal text-white overflow-hidden" data-color="dark">
    <div class="max-w-[1600px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

        <div>
          <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-light gsap-history-el">
            Trayectoria
          </span>
          <h2 class="font-serif text-[3rem] md:text-[5rem] leading-[0.9] tracking-tighter mb-10 gsap-history-el">
            Desde <span class="italic text-white/80">1976.</span>
          </h2>
          <p class="font-sans text-lg leading-relaxed text-white/70 mb-10 max-w-lg gsap-history-el">
            Comenzamos como una clínica dental familiar y crecimos hasta convertirnos en el centro médico integral de referencia del Valle de los Chillos. Dos generaciones de especialistas comprometidos con la salud de tu familia.
          </p>
          <blockquote class="border-l-2 border-brand-accent pl-8 gsap-history-el">
            <p class="font-serif text-xl md:text-2xl italic text-white/90 leading-relaxed">
              "Dos generaciones transformando sonrisas y salud."
            </p>
            <cite class="block mt-4 font-sans text-xs uppercase tracking-widest text-brand-light not-italic">
              Odontomed S.A.
            </cite>
          </blockquote>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 gap-px bg-white/10 border border-white/10 gsap-history-stats">
          <div class="bg-brand-teal p-10 lg:p-12">
            <p class="font-serif text-[4rem] md:text-[6rem] leading-none tracking-tighter text-white">+40</p>
            <p class="font-sans text-xs uppercase tracking-widest text-brand-light mt-3">Años de trayectoria</p>
          </div>
          <div class="bg-white/10 p-10 lg:p-12">
            <p class="font-serif text-[4rem] md:text-[6rem] leading-none tracking-tighter text-white">2</p>
            <p class="font-sans text-xs uppercase tracking-widest text-brand-light mt-3">Generaciones</p>
          </div>
          <div class="bg-white/10 p-10 lg:p-12">
            <p class="font-serif text-[4rem] md:text-[6rem] leading-none tracking-tighter text-white">13</p>
            <p class="font-sans text-xs uppercase tracking-widest text-brand-light mt-3">Especialidades</p>
          </div>
          <div class="bg-brand-teal p-10 lg:p-12">
            <p class="font-serif text-[4rem] md:text-[6rem] leading-none tracking-tighter text-white">1</p>
            <p class="font-sans text-xs uppercase tracking-widest text-brand-light mt-3">Solo clínica integral</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Nuestros Inicios ─────────────────────────────────────────────────── -->
  {oldPhotos.length > 0 && (
    <section class="py-24 md:py-32 px-6 lg:px-12 bg-white overflow-hidden" data-color="light">
      <div class="max-w-[1600px] mx-auto">
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-accent gsap-origins-header">
          Historia
        </span>
        <h2 class="font-serif text-[3rem] md:text-[5rem] leading-[0.9] tracking-tighter text-brand-teal mb-16 gsap-origins-header">
          Nuestros <span class="italic">Inicios.</span>
        </h2>
        <div class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory gsap-origins-strip">
          {oldPhotos.map((p) => (
            <div class="shrink-0 snap-start w-[280px] sm:w-[340px] md:w-[400px]">
              <div class="overflow-hidden rounded-lg h-[300px] sm:h-[360px]">
                <img
                  src={urlFor(p.photo).width(800).auto('format').url()}
                  alt={p.year ? `Odontomed ${p.year}` : 'Odontomed — archivo histórico'}
                  class="w-full h-full object-cover grayscale sepia hover:sepia-0 transition-all duration-700"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              {p.year && (
                <p class="mt-3 font-sans text-xs uppercase tracking-widest text-brand-teal/40">{p.year}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ── Nuestra Clínica ────────────────────────────────────────────────── -->
  {clinicPhotos.length > 0 && (
    <section id="galeria" class="py-24 md:py-32 px-6 lg:px-12 bg-brand-soft" data-color="soft">
      <div class="max-w-[1600px] mx-auto">
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-accent gsap-gallery-header">
          Instalaciones
        </span>
        <h2 class="font-serif text-[3rem] md:text-[5rem] leading-[0.9] tracking-tighter text-brand-teal mb-16 gsap-gallery-header">
          Nuestra <span class="italic">Clínica.</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {clinicPhotos.map((p, i) => (
            <button
              type="button"
              class="gsap-gallery-card group relative overflow-hidden rounded-xl cursor-pointer block w-full text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
              data-lightbox-src={urlFor(p.photo).width(1400).auto('format').url()}
              data-lightbox-label={p.label}
              aria-label={`Ver foto: ${p.label}`}
            >
              <div class="h-64 sm:h-72 overflow-hidden">
                <img
                  src={urlFor(p.photo).width(800).height(600).fit('crop').auto('format').url()}
                  alt={p.label}
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
              <div class="absolute inset-0 pointer-events-none" style="background: linear-gradient(to top, rgba(34,74,79,0.75) 0%, transparent 50%)" />
              <div class="absolute bottom-0 left-0 right-0 px-5 py-4 flex items-end justify-between">
                <p class="font-sans text-sm text-white font-semibold tracking-wide">{p.label}</p>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/70 shrink-0" aria-hidden="true">
                  <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/>
                </svg>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Lightbox -->
      <dialog id="clinic-lightbox" class="fixed inset-0 w-full h-full max-w-none max-h-none bg-transparent p-0 m-0 backdrop:bg-black/80">
        <div class="w-full h-full flex flex-col items-center justify-center p-4 sm:p-8" id="lightbox-backdrop">
          <div class="relative max-w-5xl w-full">
            <img id="lightbox-img" src="" alt="" class="w-full max-h-[80vh] object-contain rounded-lg shadow-2xl" />
            <p id="lightbox-label" class="mt-4 text-center font-sans text-sm uppercase tracking-widest text-white/70"></p>
          </div>
          <button id="lightbox-close" class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors" aria-label="Cerrar">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </dialog>
    </section>
  )}

  <!-- ── Valores ─────────────────────────────────────────────────────────── -->
  <section id="valores" class="py-24 md:py-40 px-6 lg:px-12 bg-brand-soft" data-color="soft">
    <div class="max-w-[1600px] mx-auto">

      <div class="flex flex-col md:flex-row justify-between items-end mb-16 md:mb-24 gap-8">
        <div>
          <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-brand-accent gsap-values-header">
            Cultura Organizacional
          </span>
          <h2 class="font-serif text-[3rem] md:text-[5.5rem] leading-[0.85] tracking-tighter text-brand-teal gsap-values-header">
            Nuestros<br /><span class="italic" style="-webkit-text-stroke: 1px #448087; color: transparent;">Valores.</span>
          </h2>
        </div>
        <p class="font-sans text-base text-brand-teal/60 max-w-sm gsap-values-header">
          Principios que guían cada consulta, cada diagnóstico y cada tratamiento desde el primer día.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-brand-teal/10 border border-brand-teal/10">

        <!-- Experiencia -->
        <div class="bg-brand-soft p-10 hover:bg-white transition-colors duration-300 gsap-value-card">
          <p class="font-serif text-[3rem] text-brand-teal/20 leading-none mb-6">01</p>
          <h3 class="font-serif text-2xl text-brand-teal mb-4">Experiencia</h3>
          <p class="font-sans text-sm text-brand-teal/60 leading-relaxed">
            Respaldo de dos generaciones desde 1976. Décadas de casos resueltos y familias atendidas nos dan la solidez que nos distingue.
          </p>
        </div>

        <!-- Innovación -->
        <div class="bg-brand-soft p-10 hover:bg-white transition-colors duration-300 gsap-value-card">
          <p class="font-serif text-[3rem] text-brand-teal/20 leading-none mb-6">02</p>
          <h3 class="font-serif text-2xl text-brand-teal mb-4">Innovación</h3>
          <p class="font-sans text-sm text-brand-teal/60 leading-relaxed">
            Uso de tecnología avanzada en cada tratamiento. Equipos de diagnóstico 3D, software de diseño de sonrisa digital y técnicas de vanguardia.
          </p>
        </div>

        <!-- Confianza -->
        <div class="bg-brand-soft p-10 hover:bg-white transition-colors duration-300 gsap-value-card">
          <p class="font-serif text-[3rem] text-brand-teal/20 leading-none mb-6">03</p>
          <h3 class="font-serif text-2xl text-brand-teal mb-4">Confianza</h3>
          <p class="font-sans text-sm text-brand-teal/60 leading-relaxed">
            Relación cercana y transparente con los pacientes. Diagnósticos honestos, presupuestos claros y comunicación directa en cada etapa.
          </p>
        </div>

        <!-- Calidad -->
        <div class="bg-brand-soft p-10 hover:bg-white transition-colors duration-300 gsap-value-card">
          <p class="font-serif text-[3rem] text-brand-teal/20 leading-none mb-6">04</p>
          <h3 class="font-serif text-2xl text-brand-teal mb-4">Calidad</h3>
          <p class="font-sans text-sm text-brand-teal/60 leading-relaxed">
            Servicios especializados con estándares internacionales. Materiales premium, protocolos clínicos rigurosos y control de calidad en cada procedimiento.
          </p>
        </div>

        <!-- Empatía -->
        <div class="bg-brand-soft p-10 hover:bg-white transition-colors duration-300 gsap-value-card">
          <p class="font-serif text-[3rem] text-brand-teal/20 leading-none mb-6">05</p>
          <h3 class="font-serif text-2xl text-brand-teal mb-4">Empatía</h3>
          <p class="font-sans text-sm text-brand-teal/60 leading-relaxed">
            Cuidado integral centrado en las necesidades del paciente. Escuchamos, entendemos y adaptamos cada tratamiento a tu historia y tus metas.
          </p>
        </div>

        <!-- Filosofía -->
        <div class="bg-brand-teal p-10 gsap-value-card">
          <p class="font-serif text-[3rem] text-white/20 leading-none mb-6">—</p>
          <h3 class="font-serif text-2xl text-white mb-4">Nuestra Filosofía</h3>
          <p class="font-sans text-sm text-white/70 leading-relaxed italic">
            "Cada sonrisa que transformamos es un logro compartido."
          </p>
          <span class="block mt-6 font-sans text-xs uppercase tracking-widest text-brand-light">
            Equipo Odontomed S.A.
          </span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA Final ──────────────────────────────────────────────────────── -->
  <section class="py-24 md:py-40 px-6 lg:px-12 bg-white" data-color="light">
    <div class="max-w-[680px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_220px] items-stretch rounded-2xl overflow-hidden" style="box-shadow: 0 8px 40px rgba(68,128,135,0.12), 0 2px 8px rgba(0,0,0,0.06)">

      <!-- Contenido izquierdo -->
      <div class="bg-white px-10 py-12 flex flex-col justify-center">
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-5 text-brand-accent gsap-cta-about">
          Comienza hoy
        </span>
        <h2 class="font-serif text-[2.4rem] md:text-[3.2rem] leading-[0.9] tracking-tighter text-brand-teal mb-8 gsap-cta-about">
          Tu salud<br />
          <span class="italic" style="-webkit-text-stroke: 1px #448087; color: transparent;">es nuestra misión.</span>
        </h2>
        <ul class="font-sans text-xs uppercase tracking-widest space-y-4 mb-10 gsap-cta-about">
          <li class="flex items-center gap-3 text-brand-teal/70">
            <span class="w-6 h-[1px] bg-brand-accent flex-shrink-0"></span>
            Más de 40 años de experiencia clínica
          </li>
          <li class="flex items-center gap-3 text-brand-teal/70">
            <span class="w-6 h-[1px] bg-brand-accent flex-shrink-0"></span>
            13 especialidades odontológicas y médicas
          </li>
          <li class="flex items-center gap-3 text-brand-teal/70">
            <span class="w-6 h-[1px] bg-brand-accent flex-shrink-0"></span>
            Tecnología de diagnóstico de última generación
          </li>
        </ul>
        <div class="flex flex-col sm:flex-row items-start gap-4 gsap-cta-about">
          <a
            href="https://wa.me/593979286633"
            target="_blank" rel="noopener noreferrer"
            class="bg-brand-accent text-white px-7 py-3 text-xs uppercase tracking-widest hover:bg-brand-teal transition-colors duration-300 font-bold"
          >
            Agendar cita
          </a>
          <a
            href="/servicios"
            class="border-b border-brand-teal/40 pb-1 font-sans text-xs uppercase tracking-widest hover:text-brand-accent transition-colors text-brand-teal self-center"
          >
            Ver especialidades
          </a>
        </div>
      </div>

      <!-- Imagen derecha: fondo teal + imagen desde abajo -->
      <div class="hidden lg:flex relative bg-brand-teal overflow-hidden gsap-cta-about">
        <img
          src="https://cdn.sanity.io/images/g6lpsvgv/production/c33c9e49cb9ef4dbb0926b8b54d8b36153137066-775x1033.heif"
          alt="Especialista Odontomed"
          class="absolute bottom-0 left-1/2 -translate-x-1/2 h-full w-auto max-w-none object-contain object-bottom"
          loading="lazy"
          decoding="async"
        />
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap || !window.ScrollTrigger) return;

    // Hero
    gsap.fromTo('.gsap-about-hero',
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 1, stagger: 0.12, ease: 'power3.out', delay: 0.2 }
    );

    // Misión & Visión
    gsap.fromTo('.gsap-mv-el',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: '#mision', start: 'top 85%', once: true } }
    );
    gsap.fromTo('.gsap-mv-card',
      { y: 50, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.9, stagger: 0.15, ease: 'power2.out',
        scrollTrigger: { trigger: '#mision', start: 'top 80%', once: true } }
    );

    // Historia
    gsap.fromTo('.gsap-history-el',
      { x: -40, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.9, stagger: 0.12, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-history-el', start: 'top 85%', once: true } }
    );
    gsap.fromTo('.gsap-history-stats',
      { x: 40, opacity: 0 },
      { x: 0, opacity: 1, duration: 0.9, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-history-stats', start: 'top 85%', once: true } }
    );

    // Valores
    gsap.fromTo('.gsap-values-header',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
        scrollTrigger: { trigger: '#valores', start: 'top 85%', once: true } }
    );
    gsap.fromTo('.gsap-value-card',
      { y: 50, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, stagger: 0.08, ease: 'power2.out',
        scrollTrigger: { trigger: '#valores', start: 'top 75%', once: true } }
    );

    // Inicios
    gsap.fromTo('.gsap-origins-header',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-origins-header', start: 'top 85%', once: true } }
    )
    gsap.fromTo('.gsap-origins-strip',
      { x: 60, opacity: 0 },
      { x: 0, opacity: 1, duration: 1, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-origins-strip', start: 'top 85%', once: true } }
    )

    // Galería clínica
    gsap.fromTo('.gsap-gallery-header',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-gallery-header', start: 'top 85%', once: true } }
    )
    gsap.fromTo('.gsap-gallery-card',
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.7, stagger: 0.08, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-gallery-card', start: 'top 85%', once: true } }
    )

    // Lightbox
    const lightbox   = document.getElementById('clinic-lightbox')
    const lbImg      = document.getElementById('lightbox-img')
    const lbLabel    = document.getElementById('lightbox-label')
    const lbClose    = document.getElementById('lightbox-close')
    const lbBackdrop = document.getElementById('lightbox-backdrop')

    document.querySelectorAll('[data-lightbox-src]').forEach((btn) => {
      btn.addEventListener('click', () => {
        lbImg.src     = btn.dataset.lightboxSrc
        lbImg.alt     = btn.dataset.lightboxLabel
        lbLabel.textContent = btn.dataset.lightboxLabel
        lightbox.showModal()
        document.body.style.overflow = 'hidden'
      })
    })

    const closeLightbox = () => {
      lightbox.close()
      lbImg.src = ''
      document.body.style.overflow = ''
    }

    lbClose?.addEventListener('click', closeLightbox)
    lbBackdrop?.addEventListener('click', (e) => { if (e.target === lbBackdrop) closeLightbox() })
    lightbox?.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox() })

    // CTA
    gsap.fromTo('.gsap-cta-about',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8, stagger: 0.1, ease: 'power2.out',
        scrollTrigger: { trigger: '.gsap-cta-about', start: 'top 85%', once: true } }
    );
  });
</script>
