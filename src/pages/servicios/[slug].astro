---
import BaseLayout        from '../../layouts/BaseLayout.astro';
import Navbar             from '../../components/Navbar.astro';
import Footer             from '../../components/Footer.astro';
import SpecialistModal    from '../../components/ui/SpecialistModal.astro';
import { getServiceBySlug } from '../../utils/services';
import type { ServiceBenefit } from '../../utils/services';
import { getSiteSettings } from '../../lib/settings';

const { slug } = Astro.params;
const [service, settings] = await Promise.all([
  getServiceBySlug(slug!),
  getSiteSettings(),
]);

if (!service) {
  return Astro.redirect('/404');
}

const waNumber  = settings.whatsapp?.replace(/\D/g, '') ?? '593979286633'
const waMessage = encodeURIComponent(`Hola, me gustaría agendar el tratamiento de ${service.title}. ¿Podría darme más información?`)
const waHref    = `https://wa.me/${waNumber}?text=${waMessage}`

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "MedicalProcedure",
      "@id": `https://odonto-med.com/servicios/${slug}#procedure`,
      "name": service.title,
      "description": service.desc,
      "procedureType": "https://schema.org/SurgicalProcedure",
      "bodyLocation": "Boca, dientes y encías",
      "followup": "Consulta de seguimiento con el especialista",
      "howPerformed": service.body
        ?.filter((b: any) => b._type === 'block')
        .map((b: any) => b.children?.map((s: any) => s.text).join(''))
        .join(' ')
        .slice(0, 500) || service.desc,
      "performer": {
        "@type": "MedicalOrganization",
        "@id": "https://odonto-med.com/#organization",
        "name": "Odontomed"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio",    "item": "https://odonto-med.com" },
        { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://odonto-med.com/servicios" },
        { "@type": "ListItem", "position": 3, "name": service.title, "item": `https://odonto-med.com/servicios/${slug}` }
      ]
    }
  ]
})

// Beneficios: usa los del CMS o fallback por defecto
const benefits: ServiceBenefit[] = service.benefits?.length
  ? service.benefits
  : [
      { _key: 'b1', title: 'Resultados duraderos',    description: 'Alta estética y funcionalidad inmediata.' },
      { _key: 'b2', title: 'Recuperación rápida',     description: 'Técnicas mínimamente invasivas.' },
      { _key: 'b3', title: 'Materiales premium',      description: 'Biocompatibles y de alta resistencia.' },
      { _key: 'b4', title: 'Atención personalizada',  description: 'Seguimiento continuo de tu especialista.' },
    ];

// Texto "¿Por qué elegirnos?" con fallback
const whyUs = service.whyUs ||
  'Utilizamos protocolos internacionales y materiales de primera calidad certificados. Tu salud es nuestra prioridad número uno en el Valle de los Chillos.';
---

<BaseLayout
  title={service.seo?.metaTitle ?? `${service.title} | Odontomed — ${service.category} en Conocoto`}
  description={service.seo?.metaDescription ?? `${service.desc} Tratamiento de ${service.title.toLowerCase()} en Odontomed, clínica dental en Conocoto, Valle de los Chillos, Quito.`}
  ogImage={service.imgUrl}
  bodyTheme="dark"
  schema={serviceSchema}
>
  <Navbar />

  <!-- Hero -->
  <section class="pt-40 pb-20 px-6 lg:px-12 min-h-[70vh] flex flex-col justify-center bg-brand-teal text-white border-b border-white/10" data-color="dark">
    <div class="max-w-[1600px] mx-auto w-full flex flex-col lg:flex-row items-center gap-16">

      <div class="w-full lg:w-1/2">
        <a href="/servicios" class="mb-10 font-sans text-xs uppercase tracking-widest text-brand-light hover:text-white transition-colors flex items-center gap-2 gsap-detail-hero inline-flex">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
          Volver a Servicios
        </a>
        <span class="block text-[0.65rem] uppercase tracking-[0.3em] font-sans font-semibold mb-6 text-white/50 gsap-detail-hero">
          {service.category}
        </span>
        <h1 class="font-serif text-[4rem] md:text-[6rem] leading-[0.9] tracking-tighter mb-8 gsap-detail-hero">
          {service.title}
        </h1>
        <p class="font-sans text-xl opacity-90 max-w-lg gsap-detail-hero">{service.desc}</p>
        <div class="mt-12 gsap-detail-hero">
          <a href={waHref} target="_blank" rel="noopener noreferrer" class="bg-white text-brand-teal px-8 py-4 text-sm uppercase tracking-widest hover:scale-105 transition-transform duration-300 border border-white inline-block font-bold">
            Agendar este tratamiento
          </a>
        </div>
      </div>

      <div class="w-full lg:w-1/2 h-[50vh] lg:h-[60vh] overflow-hidden gsap-detail-hero border border-white/20">
        {service.imgUrl ? (
          <img
            src={service.imgUrl}
            alt={`Tratamiento de ${service.title} en Odontomed`}
            class="w-full h-full object-cover"
            loading="lazy" width="800" height="600"
          />
        ) : (
          <div class="w-full h-full bg-brand-teal/30 flex items-center justify-center">
            <span class="font-sans text-sm uppercase tracking-widest text-white/40">{service.title}</span>
          </div>
        )}
      </div>

    </div>
  </section>

  <!-- Body -->
  <section class="py-32 px-6 lg:px-12 bg-white" data-color="light">
    <div class="max-w-[1400px] mx-auto flex flex-col md:flex-row gap-20">

      <div class="w-full md:w-2/3 gsap-detail-content text-brand-teal">
        <h2 class="font-serif text-[3rem] md:text-[4rem] leading-none mb-8">
          Sobre el <span class="italic text-brand-teal">Procedimiento.</span>
        </h2>

        {service.body?.length ? (
          // Contenido del CMS (Portable Text — bloques de texto simples)
          service.body
            .filter((b: any) => b._type === 'block')
            .map((b: any) => (
              <p class="font-sans text-lg leading-relaxed mb-6 opacity-80">
                {b.children?.map((s: any) => s.text).join('')}
              </p>
            ))
        ) : (
          // Texto por defecto mientras el CMS está vacío
          <>
            <p class="font-sans text-xl leading-relaxed mb-8 opacity-80">
              En Odontomed diseñamos cada etapa de tu tratamiento pensando en tu bienestar y en resultados a largo plazo. Este procedimiento se realiza utilizando tecnología de vanguardia para asegurar el mínimo dolor, reduciendo los tiempos de recuperación y maximizando la eficacia.
            </p>
            <p class="font-sans text-lg leading-relaxed mb-12 opacity-80">
              Nuestro equipo de especialistas te acompañará durante todo el proceso, comenzando con un diagnóstico honesto y preciso. Resolvemos todas tus dudas y aseguramos que tu experiencia sea completamente satisfactoria desde la primera consulta hasta el alta final.
            </p>
          </>
        )}

        <div class="bg-brand-teal/5 p-8 border-l-2 border-brand-accent mt-4">
          <h3 class="font-sans text-sm uppercase tracking-widest font-bold mb-4 text-brand-teal">¿Por qué elegirnos?</h3>
          <p class="font-sans text-base opacity-80">{whyUs}</p>
        </div>
      </div>

      <!-- Sidebar de beneficios -->
      <aside class="w-full md:w-1/3 gsap-detail-content">
        <div class="border border-white/20 p-8 sticky top-32 bg-brand-teal text-white">
          <h3 class="font-sans text-sm uppercase tracking-widest font-bold mb-8 text-brand-light">Beneficios Clave</h3>
          <ul class="space-y-6 font-sans text-sm opacity-80">
            {benefits.map((b) => (
              <li class="flex items-start gap-4" key={b._key}>
                <span class="text-brand-light text-xl leading-none">✓</span>
                <span>
                  <strong>{b.title}</strong>
                  {b.description && <><br />{b.description}</>}
                </span>
              </li>
            ))}
          </ul>
        </div>
      </aside>

    </div>
  </section>

  <!-- ── Especialistas ──────────────────────────────────────────── -->
  {service.specialists && service.specialists.length > 0 && (
    <section class="py-20 px-6 lg:px-12 bg-brand-soft border-t border-brand-teal/10" data-color="soft">
      <div class="max-w-[1600px] mx-auto">
        <span class="block font-sans text-[0.65rem] uppercase tracking-[0.3em] font-semibold text-brand-accent mb-6">
          Nuestro equipo
        </span>
        <h2 class="font-serif text-[2rem] md:text-[3rem] leading-[0.9] tracking-tighter text-brand-teal mb-14">
          Especialistas en <span class="italic">{service.category}</span>
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">
          {service.specialists.map((s) => (
            <button
              type="button"
              data-specialist-id={s._id}
              aria-label={`Ver perfil de ${s.name}`}
              class="rounded-2xl overflow-hidden relative h-80 sm:h-96 bg-brand-teal/10 w-full text-left cursor-pointer group focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-accent"
            >
              <!-- Foto -->
              {s.photoUrl ? (
                <img
                  src={s.photoUrl}
                  alt={s.name}
                  class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="font-serif font-bold text-[5rem] text-brand-teal/20 select-none">
                    {s.name.charAt(0)}
                  </span>
                </div>
              )}

              <!-- Overlay degradado -->
              <div class="absolute inset-0 transition-opacity duration-300 group-hover:opacity-80"
                   style="background: linear-gradient(to top, rgba(34,74,79,0.88) 0%, rgba(34,74,79,0.4) 30%, transparent 65%)" />

              <!-- Nombre y especialidad -->
              <div class="absolute bottom-0 left-0 right-0 px-5 py-5">
                <p class="font-serif text-white text-base leading-snug">{s.name}</p>
                {s.specialty && (
                  <p class="font-sans text-[0.6rem] uppercase tracking-widest text-brand-light mt-1">{s.specialty}</p>
                )}
              </div>

              <!-- Indicador "ver más" -->
              <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1">
                <span class="font-sans text-[0.55rem] uppercase tracking-widest text-white">Ver perfil</span>
              </div>

            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  {service.specialists && service.specialists.length > 0 && (
    <SpecialistModal specialists={service.specialists} />
  )}

  <Footer />
</BaseLayout>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    if (!window.gsap) return;
    gsap.fromTo('.gsap-detail-hero',    { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1, stagger: 0.1,  ease: 'power2.out' });
    gsap.fromTo('.gsap-detail-content', { y: 50, opacity: 0 }, {
      y: 0, opacity: 1, duration: 1, stagger: 0.15, ease: 'power2.out',
      scrollTrigger: { trigger: '.gsap-detail-content', start: 'top 75%' },
    });
  });
</script>
